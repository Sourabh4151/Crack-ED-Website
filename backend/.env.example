# Django – for production set DEBUG=False and a strong SECRET_KEY
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Production (crack-ed.com): add frontend URL(s) so CORS and CSRF work
# CORS_ORIGINS=https://crack-ed.com,https://www.crack-ed.com

# PostgreSQL – use either DATABASE_URL or DB_* vars
# DATABASE_URL=postgresql://user:password@localhost:5432/cracked_db
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Extraaedge CRM – token must be set for leads/quiz to be forwarded to CRM (keep secret)
# EXTRAEDGE_AUTH_TOKEN=your-extraaedge-auth-token
EXTRAEDGE_AUTH_TOKEN=crack-ed_29-01-2025

# NoPaperForms CRM – leads/quiz are forwarded when both keys are set (keep secret; rotate if exposed)
# NOPAPERFORMS_API_URL=https://api.nopaperforms.io/lead/v1/createOrUpdate
NOPAPERFORMS_ACCESS_KEY=
NOPAPERFORMS_SECRET_KEY=
# How to send credentials: headers (default), body, or basic
# NOPAPERFORMS_AUTH_MODE=headers
# Default header names are access-key and secret-key (not access_key — some stacks strip _ headers).
# If you still get 401, try: NOPAPERFORMS_AUTH_MODE=body
# Or match Postman exactly, e.g. NOPAPERFORMS_ACCESS_HEADER=access_key NOPAPERFORMS_SECRET_HEADER=secret_key
# CRM JSON includes source (default Website) and cf_form_name from source page path; override source if needed:
# NOPAPERFORMS_SOURCE_VALUE=Website

# Marketing blog admin (React /marketing/blogs) now uses Django staff login + CSRF.
# Create/manage users from Django admin or:
# python manage.py createsuperuser