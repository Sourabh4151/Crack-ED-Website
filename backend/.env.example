# Django – for production set DEBUG=False and a strong SECRET_KEY
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Production (crack-ed.com): add frontend URL(s) so CORS and CSRF work
# CORS_ORIGINS=https://crack-ed.com,https://www.crack-ed.com

# PostgreSQL – use either DATABASE_URL or DB_* vars
# DATABASE_URL=postgresql://user:password@localhost:5432/cracked_db
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Extraaedge CRM – token must be set for leads/quiz to be forwarded to CRM (keep secret)
# EXTRAEDGE_AUTH_TOKEN=your-extraaedge-auth-token
EXTRAEDGE_AUTH_TOKEN=crack-ed_29-01-2025

# Marketing blog admin (React /admin/blogs) — paste same value in the UI; generate e.g. python -c "import secrets; print(secrets.token_hex(32))"
BLOG_ADMIN_TOKEN=52dbfe7730bedec80b559b6fa5f4206a6743b7ab6ff66fef0130846a98eca1c2